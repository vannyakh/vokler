{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["chrome"]
  },
  "include": ["background/**/*.ts", "content/**/*.ts", "popup/**/*.ts", "popup/**/*.tsx"]
}
